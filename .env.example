# ═══════════════════════════════════════════════════════════
#  MediAgent v5 — Environment Variables
#  Copy this to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# ── LLM: Claude Haiku (FASTEST, CHEAPEST — RECOMMENDED) ──
# New Anthropic accounts get ~$5 free credit.
# Claude Haiku 4.5 uses ~$0.001 per typical chat message.
# Get your key: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── LLM: Ollama fallback (used if no Anthropic key) ───────
# Install: https://ollama.com  |  Run: ollama run phi3:mini
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=phi3:mini

# ── Email — Gmail SMTP (free) ─────────────────────────────
# 1. Enable 2FA on your Google account
# 2. Go to: myaccount.google.com/apppasswords
# 3. Create App Password → "Mail" → copy 16-char code
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_FROM=MediAgent <your@gmail.com>

# ── WhatsApp — Twilio Sandbox (free to test) ──────────────
# 1. Sign up free at: https://twilio.com
# 2. Messaging → Try it out → Send a WhatsApp message
# 3. Text "join <word>" to +1 415 523 8886 from YOUR WhatsApp
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Auto scheduled reminders ─────────────────────────────
# Set these to enable the background scheduler:
#   Daily 7 AM UTC  → medication reminders
#   Hourly          → appointment reminders (24h ahead)
#   Every Monday 8AM→ weekly adherence report + PDF
REMINDER_EMAIL=your@gmail.com
REMINDER_PHONE=+1234567890
